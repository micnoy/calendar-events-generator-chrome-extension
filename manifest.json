{
  "manifest_version": 3,
  "name": "Calendar Event Link Generator",
  "description": "Parse natural language dates with AI and generate Google Calendar event links.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Generate Calendar Event Link"
  },
  "permissions": [
    "storage"
  ]
}
